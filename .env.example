# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_news_navigator

# Web
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CRON_SECRET=

# Story analysis. A direct DeepSeek key takes priority and uses V4 Flash in
# non-thinking JSON mode by default. Override the base URL for an OpenAI-
# compatible relay. Keep every key in your environment, never in Git.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional direct OpenAI fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Optional fallback through Vercel AI Gateway. Production deployments receive
# VERCEL_OIDC_TOKEN automatically; use AI_GATEWAY_API_KEY only for local runs.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-5-nano

# Jobs
INGESTION_CONCURRENCY=4
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_news_navigator

# Web
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CRON_SECRET=

# Story analysis. A direct OpenAI key takes priority and uses the low-cost
# GPT-5 nano model by default. Keep the key in your environment, never in Git.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Optional fallback through Vercel AI Gateway. Production deployments receive
# VERCEL_OIDC_TOKEN automatically; use AI_GATEWAY_API_KEY only for local runs.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=openai/gpt-5-nano

# Jobs
INGESTION_CONCURRENCY=4
LOG_LEVEL=info

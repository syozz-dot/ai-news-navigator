# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_news_navigator

# Web
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CRON_SECRET=

# Story analysis through Vercel AI Gateway. Production deployments receive
# VERCEL_OIDC_TOKEN automatically; use AI_GATEWAY_API_KEY only for local runs.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=alibaba/qwen3.5-flash

# Jobs
INGESTION_CONCURRENCY=4
LOG_LEVEL=info
